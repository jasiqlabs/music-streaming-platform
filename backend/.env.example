# Server
PORT=8000
APP_BASE_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/music_platform

# Auth
JWT_SECRET=your-jwt-secret-change-in-production

# Storage provider: local | firebase | s3
STORAGE_PROVIDER=firebase 

# Local storage
LOCAL_STORAGE_ROOT=./storage
LOCAL_PRIVATE_STREAM_ROUTE=/media/stream

# Firebase (required when STORAGE_PROVIDER=firebase)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# AWS S3 (required when STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
AWS_S3_SIGNED_URL_EXPIRES_IN=300

# Media access / security
MEDIA_SIGNED_TOKEN_SECRET=
MEDIA_URL_TTL_SECONDS=300

# Upload limits (MB)
MAX_UPLOAD_AUDIO_MB=50
MAX_UPLOAD_VIDEO_MB=500
MAX_UPLOAD_IMAGE_MB=10
